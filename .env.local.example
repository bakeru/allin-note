# ===== Supabase =====
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=allin-note-audio
R2_ENDPOINT=

# OpenAI
OPENAI_API_KEY=

# Resend
RESEND_API_KEY=
EMAIL_FROM=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=

# β版フラグ
NEXT_PUBLIC_IS_BETA=true
BETA_MAX_LESSONS_PER_MONTH=30
BETA_MAX_RECORDING_MINUTES=90

# 認証モード(開発用)
NEXT_PUBLIC_AUTH_MODE=mock

# モック認証(NEXT_PUBLIC_AUTH_MODE=mock の時のみ)
NEXT_PUBLIC_USE_MOCK_AUTH=true
NEXT_PUBLIC_MOCK_USER_ID=00000000-0000-0000-0000-000000000001
MOCK_USER_ID=00000000-0000-0000-0000-000000000001
NEXT_PUBLIC_MOCK_ROLE=teacher

# 開発用の生徒ID(手動でSupabaseに作成した生徒のUUID)
NEXT_PUBLIC_DEV_STUDENT_ID=
